rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function emailVerified() { return request.auth.token.email_verified == true; }
    
    // Admin check: assumes a document exists in /users/{userId} with isAdmin: true
    // Or better, a dedicated /admins/{userId} collection
    function isAdmin() { 
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidSpeaker(data) {
      return data.keys().hasAll(['name']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             (!('bio' in data) || (data.bio is string && data.bio.size() <= 5000)) &&
             (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() <= 1000));
    }

    function isValidCategory(data) {
      return data.keys().hasAll(['name']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100;
    }

    function isValidContent(data) {
      return data.keys().hasAll(['title', 'slug', 'type', 'speakerId', 'categoryId', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 500 &&
             data.slug is string && data.slug.size() > 0 && data.slug.size() <= 500 &&
             data.type in ['ARTICLE', 'AUDIO', 'VIDEO', 'PDF'] &&
             data.speakerId is string &&
             data.categoryId is string &&
             data.createdAt is timestamp &&
             (!('description' in data) || (data.description is string && data.description.size() <= 2000)) &&
             (!('body' in data) || (data.body is string && data.body.size() <= 100000)) &&
             (!('mediaUrl' in data) || (data.mediaUrl is string && data.mediaUrl.size() <= 2000)) &&
             (!('courseId' in data) || (data.courseId == null || data.courseId is string)) &&
             (!('youtubeId' in data) || (data.youtubeId is string && data.youtubeId.size() <= 100)) &&
             (!('isFeatured' in data) || (data.isFeatured is bool));
    }

    function isValidCourse(data) {
      return data.keys().hasAll(['title', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             (!('description' in data) || (data.description is string && data.description.size() <= 2000)) &&
             data.createdAt is timestamp;
    }

    function isValidBenefit(data) {
      return data.keys().hasAll(['text', 'createdAt']) &&
             data.text is string && data.text.size() > 0 && data.text.size() <= 10000 &&
             data.createdAt is timestamp;
    }

    // --- Collections ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && incoming().isAdmin == false;
      allow update: if isOwner(userId) && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'email']) &&
                      incoming().email == existing().email;
    }

    match /admins/{userId} {
      allow read: if isSignedIn(); // Allow checking if user is admin
      allow write: if false; // Strict: only via console or service account
    }

    match /speakers/{speakerId} {
      allow read: if true;
      allow create, update: if isSignedIn() && isValidSpeaker(incoming());
      allow delete: if isSignedIn();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow create, update: if isSignedIn() && isValidCategory(incoming());
      allow delete: if isSignedIn();
    }

    match /contents/{contentId} {
      allow read: if true;
      allow create, update: if isSignedIn() && isValidContent(incoming());
      allow delete: if isSignedIn();
    }

    match /courses/{courseId} {
      allow read: if true;
      allow create, update: if isSignedIn() && isValidCourse(incoming());
      allow delete: if isSignedIn();
    }

    match /fawaaid/{benefitId} {
      allow read: if true;
      allow create, update: if isSignedIn() && isValidBenefit(incoming());
      allow delete: if isSignedIn();
    }
  }
}
